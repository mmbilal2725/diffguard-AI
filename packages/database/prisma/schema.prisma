generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PullRequestStatus {
  OPEN
  CLOSED
  MERGED
}

enum ReviewRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELED
  SKIPPED
}

enum FindingSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FindingCategory {
  LOGIC         @map("logic")
  SECURITY      @map("security")
  PERFORMANCE   @map("performance")
  RELIABILITY   @map("reliability")
  REGRESSION    @map("regression")
  TESTING       @map("testing")
  DATA_LOSS     @map("data-loss")
  API_CONTRACT  @map("api-contract")
  AUTHORIZATION @map("authorization")
  VALIDATION    @map("validation")
}

enum FindingSide {
  LEFT
  RIGHT
}

enum FindingStatus {
  VALIDATED
  POSTED
  DISMISSED
  RESOLVED
  UNRESOLVED
  FALSE_POSITIVE
  UNKNOWN
}

enum ModelCallStatus {
  SUCCEEDED
  FAILED
}

enum FeedbackEventType {
  FALSE_POSITIVE
  RESOLVED
  DISMISSED
  HELPFUL
  NOT_HELPFUL
}

model Repository {
  id                   String        @id @default(cuid())
  owner                String
  name                 String
  githubInstallationId String?
  defaultBranch        String?
  rulesPath            String        @default(".diffguard-rules.md")
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  pullRequests         PullRequest[]

  @@unique([owner, name])
  @@index([githubInstallationId])
}

model PullRequest {
  id           String            @id @default(cuid())
  repositoryId String
  number       Int
  title        String
  authorLogin  String?
  baseSha      String?
  headSha      String?
  status       PullRequestStatus @default(OPEN)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  repository   Repository        @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  reviewRuns   ReviewRun[]

  @@unique([repositoryId, number])
  @@index([repositoryId, status])
}

model ReviewRun {
  id                      String              @id @default(cuid())
  pullRequestId           String
  status                  ReviewRunStatus     @default(QUEUED)
  trigger                 String?
  githubDeliveryId        String?
  errorMessage            String?
  startedAt               DateTime?
  completedAt             DateTime?
  findingsDetected        Int                 @default(0)
  findingsPosted          Int                 @default(0)
  validatorRejectionRate  Decimal?            @db.Decimal(5, 4)
  estimatedFalsePositives Int                 @default(0)
  resolvedFindings        Int                 @default(0)
  totalCostUsd            Decimal             @default(0) @db.Decimal(12, 6)
  latencyMs               Int?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  pullRequest             PullRequest         @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  findings                Finding[]
  validatorDecisions      ValidatorDecision[]
  modelCalls              ModelCall[]
  feedbackEvents          FeedbackEvent[]

  @@index([pullRequestId, status])
  @@index([status, createdAt])
  @@index([githubDeliveryId])
  @@index([createdAt])
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  deliveryId  String   @unique
  eventName   String
  action      String?
  processedAt DateTime
  createdAt   DateTime @default(now())

  @@index([eventName, action])
  @@index([processedAt])
}

model EvalRun {
  id                     String   @id @default(cuid())
  name                   String
  modelVersion           String
  promptVersion          String
  precision              Decimal  @db.Decimal(5, 4)
  recall                 Decimal  @db.Decimal(5, 4)
  falsePositiveCount     Int      @default(0)
  falseNegativeCount     Int      @default(0)
  costUsd                Decimal  @default(0) @db.Decimal(12, 6)
  caseCount              Int
  latencyMs              Int      @default(0)
  passed                 Boolean  @default(false)
  truePositiveCount      Int      @default(0)
  validatorRejectionRate Decimal  @default(0) @db.Decimal(5, 4)
  findingsPerPr          Decimal  @default(0) @db.Decimal(8, 4)
  createdAt              DateTime @default(now())

  @@index([createdAt])
  @@index([modelVersion, promptVersion])
}

model Finding {
  id                 String              @id @default(cuid())
  reviewRunId        String
  dedupeKey          String
  title              String
  summary            String
  evidence           String
  category           FindingCategory
  severity           FindingSeverity
  confidence         Decimal             @db.Decimal(3, 2)
  filePath           String
  line               Int
  side               FindingSide         @default(RIGHT)
  suggestedFix       String?
  whyItMatters       String
  relatedRuleIds     String[]            @default([])
  status             FindingStatus       @default(VALIDATED)
  githubCommentId    String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  reviewRun          ReviewRun           @relation(fields: [reviewRunId], references: [id], onDelete: Cascade)
  feedbackEvents     FeedbackEvent[]
  validatorDecisions ValidatorDecision[]

  @@unique([reviewRunId, dedupeKey])
  @@index([reviewRunId, status])
  @@index([status, createdAt])
  @@index([filePath])
}

model ValidatorDecision {
  id                String    @id @default(cuid())
  reviewRunId       String
  findingId         String?
  findingTitle      String
  decision          String
  valid             Boolean?
  shouldPost        Boolean?
  confidence        Decimal?  @db.Decimal(5, 4)
  falsePositiveRisk String?
  reason            String
  createdAt         DateTime  @default(now())
  reviewRun         ReviewRun @relation(fields: [reviewRunId], references: [id], onDelete: Cascade)
  finding           Finding?  @relation(fields: [findingId], references: [id], onDelete: SetNull)

  @@index([reviewRunId, decision])
  @@index([findingId])
  @@index([createdAt])
}

model ModelCall {
  id            String          @id @default(cuid())
  reviewRunId   String
  provider      String
  modelName     String
  promptVersion String
  inputTokens   Int             @default(0)
  outputTokens  Int             @default(0)
  totalTokens   Int             @default(0)
  costUsd       Decimal         @default(0) @db.Decimal(12, 6)
  latencyMs     Int
  status        ModelCallStatus
  errorCode     String?
  createdAt     DateTime        @default(now())
  reviewRun     ReviewRun       @relation(fields: [reviewRunId], references: [id], onDelete: Cascade)

  @@index([reviewRunId])
  @@index([reviewRunId, createdAt])
  @@index([modelName, promptVersion])
}

model FeedbackEvent {
  id          String            @id @default(cuid())
  reviewRunId String
  findingId   String?
  type        FeedbackEventType
  actorLogin  String?
  notes       String?
  createdAt   DateTime          @default(now())
  reviewRun   ReviewRun         @relation(fields: [reviewRunId], references: [id], onDelete: Cascade)
  finding     Finding?          @relation(fields: [findingId], references: [id], onDelete: SetNull)

  @@index([reviewRunId, type])
  @@index([findingId])
}
